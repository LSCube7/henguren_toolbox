{
  "name": "henguren-toolbox-v3",
  "version": "3.0.0",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "next dev",
    "fonts:build": "node scripts/build-material-symbols.mjs",
    "fonts:check": "node scripts/build-material-symbols.mjs --check",
    "prebuild": "pnpm run fonts:check",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.705.0",
    "@material/material-color-utilities": "^0.3.0",
    "@material/web": "^2.4.0",
    "client-only": "^0.0.1",
    "next": "^16.2.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@fontsource-variable/material-symbols-rounded": "^5.2.45",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "fontverter": "^2.0.0",
    "harfbuzzjs": "^0.10.3",
    "subset-font": "^2.5.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
