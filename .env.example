LSCUBE_OAUTH_AUTHORIZE_URL=https://oauth.example.com/oauth/authorize
LSCUBE_OAUTH_TOKEN_URL=https://oauth.example.com/oauth/token
LSCUBE_OAUTH_USERINFO_URL=https://oauth.example.com/oauth/userinfo
LSCUBE_OAUTH_CLIENT_ID=
# Optional when the OAuth app uses PKCE public-client flow.
LSCUBE_OAUTH_CLIENT_SECRET=
# Optional: none, post, or basic. Defaults to post when client secret exists, otherwise none.
LSCUBE_OAUTH_CLIENT_AUTH_METHOD=
LSCUBE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
LSCUBE_OAUTH_SCOPE=openid profile email

SESSION_SECRET=replace-with-a-long-random-string

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
